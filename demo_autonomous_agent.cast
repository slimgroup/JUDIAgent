                                   \u001b[93mв”‚\u001b[0m\r\n\u001b[93mв”‚\u001b[0m                                                                                                                   \u001b[93mв”‚\u001b[0m\r\n\u001b[93mв”‚\u001b[0m I've successfully created a simple 2D acoustic forward modeling example using JUDI.jl that meets all your         \u001b[93mв”‚\u001b[0m\r\n\u001b[93mв”‚\u001b[0m requirements:                                                                                                     \u001b[93mв”‚\u001b[0m\r\n\u001b[93mв”‚\u001b[0m                                                                                                                   \u001b[93mв”‚\u001b[0m\r\n\u001b[93mв”‚\u001b[0m \u001b[1;33m 1 \u001b[0m\u001b[1mTwo-layer velocity model\u001b[0m: 1.5 km/s top layer, 3.5 km/s bottom layer                                            \u001b[93mв”‚\u001b[0m\r\n\u001b[93mв”‚\u001b[0m \u001b[1;33m 2 \u001b[0m\u001b[1m5 sources and 100 receivers\u001b[0m: All positioned at the surface (10m depth to avoid boundary issues)                \u001b[93mв”‚\u001b[0m\r\n\u001b[93mв”‚\u001b[0m \u001b[1;33m 3 \u001b[0m\u001b[1mSynthetic data generation\u001b[0m: Using forward modeling with a Ricker wavelet source                                 \u001b[93mв”‚\u001b[0m\r\n\u001b[93mв”‚\u001b[0m                                                                                                                   \u001b[93mв”‚\u001b[0m\r\n\u001b[93mв”‚\u001b[0m Here's the complete, concise code:                                                                                \u001b[93mв”‚\u001b[0m\r\n\u001b[93mв”‚\u001b[0m                                                                                                                   \u001b[93mв”‚\u001b[0m\r\n\u001b[93mв”‚\u001b[0m \u001b[48;2;39;40;34m                                                                                                                 \u001b[0m \u001b[93mв”‚\u001b[0m\r\n\u001b[93mв”‚\u001b[0m \u001b[48;2;39;40;34m \u001b[0m\u001b[38;2;149;144;119;48;2;39;40;34m# Simple 2D Acoustic Forward Modeling with JUDI.jl\u001b[0m\u001b[48;2;39;40;34m                                                             \u001b[0m\u001b[48;2;39;40;34m \u001b[0m \u001b[93mв”‚\u001b[0m\r\n\u001b[93mв”‚\u001b[0m \u001b[48;2;39;40;34m \u001b[0m\u001b[38;2;149;144;119;48;2;39;40;34m# Creates a two-layer velocity model with 5 sources and 100 receivers\u001b[0m\u001b[48;2;39;40;34m                                          \u001b[0m\u001b[48;2;39;40;34m \u001b[0m \u001b[93mв”‚\u001b[0m\r\n\u001b[93mв”‚\u001b[0m \u001b[48;2;39;40;34m \u001b[0m\u001b[48;2;39;40;34m                                                                                                               \u001b[0m\u001b[48;2;39;40;34m \u001b[0m \u001b[93mв”‚\u001b[0m\r\n\u001b[93mв”‚\u001b[0m \u001b[48;2;39;40;34m \u001b[0m\u001b[38;2;102;217;239;48;2;39;40;34musing\u001b[0m\u001b[38;2;248;248;242;48;2;39;40;34m \u001b[0m\u001b[38;2;248;248;242;48;2;39;40;34mJUDI\u001b[0m\u001b[48;2;39;40;34m                                                                                                     \u001b[0m\u001b[48;2;39;40;34m \u001b[0m \u001b[93mв”‚\u001b[0m\r\n\u001b[93mв”‚\u001b[0m \u001b[48;2;39;40;34m \u001b[0m\u001b[48;2;39;40;34m                                                                                                               \u001b[0m\u001b[48;2;39;40;34m \u001b[0m \u001b[93mв”‚\u001b[0m\r\n\u001b[93mв”‚\u001b[0m \u001b[48;2;39;40;34m \u001b[0m\u001b[38;2;149;144;119;48;2;39;40;34m# ============ 1. Create two-layer velocity model ============\u001b[0m\u001b[48;2;39;40;34m                                                 \u001b[0m\u001b[48;2;39;40;34m \u001b[0m \u001b[93mв”‚\u001b[0m\r\n\u001b[93mв”‚\u001b[0m \u001b[48;2;39;40;34m \u001b[0m\u001b[38;2;149;144;119;48;2;39;40;34m# Grid parameters\u001b[0m\u001b[48;2;39;40;34m                                                            